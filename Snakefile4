rule runCiteseqCount:
    """
    Count hashtag oligos per cell barcode.
    """
    conda:
        "malbar2.yml"
    input:
        expand("DATA/TRIMMED/{sample}_R1_001_trimmed.fastq.gz", sample=SAMPLES),
        expand("DATA/TRIMMED/{sample}_R2_001_trimmed.fastq.gz", sample=SAMPLES),
        "DATA/barcodeTags.csv",
        expand("{path004}/rnaToHtoTranslated.csv", path004=CHROM_004UM_PATH),
        expand("{path04}/rnaToHtoTranslated.csv", path04=CHROM_04UM_PATH),
        expand("{path4}/rnaToHtoTranslated.csv", path4=CHROM_4UM_PATH),
        expand("{path8}/rnaToHtoTranslated.csv", path8=CHROM_8UM_PATH)
    output:
        expand("INTERMEDIATE/CITESEQ_COUNT/{sample}/unmapped.csv", sample=SAMPLES)
    shell:
        """
        CITE-seq-Count -T 1 -R1 {input[0]} -R2 {input[4]} -t {input[8]} -cbf 1 -cbl 16 -umif 17 -umil 28 -wl {input[9]} -cells 11000 -o INTERMEDIATE/CITESEQ_COUNT/{SAMPLES[0]} -u unmapped.csv --debug >> LOGS/citeseq_debug_{SAMPLES[0]}.txt
        CITE-seq-Count -T 1 -R1 {input[1]} -R2 {input[5]} -t {input[8]} -cbf 1 -cbl 16 -umif 17 -umil 28 -wl {input[10]} -cells 11000 -o INTERMEDIATE/CITESEQ_COUNT/{SAMPLES[1]} -u unmapped.csv --debug >> LOGS/citeseq_debug_{SAMPLES[1]}.txt
        CITE-seq-Count -T 1 -R1 {input[2]} -R2 {input[6]} -t {input[8]} -cbf 1 -cbl 16 -umif 17 -umil 28 -wl {input[11]} -cells 11000 -o INTERMEDIATE/CITESEQ_COUNT/{SAMPLES[2]} -u unmapped.csv --debug >> LOGS/citeseq_debug_{SAMPLES[2]}.txt
        CITE-seq-Count -T 1 -R1 {input[3]} -R2 {input[7]} -t {input[8]} -cbf 1 -cbl 16 -umif 17 -umil 28 -wl {input[12]} -cells 11000 -o INTERMEDIATE/CITESEQ_COUNT/{SAMPLES[3]} -u unmapped.csv --debug >> LOGS/citeseq_debug_{SAMPLES[3]}.txt
        """
        
