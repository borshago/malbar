rule fastqc:
    """
    Run FastQC on the samples.
    """
    conda:
        "malbar1.yml"
    input:
        expand("DATA/FASTQ/{fastqs}", fastqs=FASTQS)
    output:
        expand("INTERMEDIATE/FASTQC/{reads}_fastqc.html", reads=READS)
    shell:
        """
        fastqc -o INTERMEDIATE/FASTQC {input}
        """

rule checkReadLengths:
    """
    Make sure that all the reads are of uniform length (important for downstream processing).
    """
    conda:
        "malbar1.yml"
    input:
        "DATA/FASTQ/{reads}.fastq.gz"
    output:
        "DATA/{reads}_lengths.txt"
    shell:
       """
       zcat DATA/FASTQ/{wildcards.reads}.fastq.gz | awk 'NR%4==2{{print length($0)}}' | uniq -c > DATA/{wildcards.reads}_lengths.txt
       """

rule lengthTrimBarcodesR2:
    """
    Trim the barcode fraction R2 reads to a uniform length (15 bp), containing the barcode sequence.
    """
    conda:
        "malbar1.yml"
    input:
        "DATA/FASTQ/{sample}_R2_001.fastq.gz"
    output:
        "DATA/TRIMMED/{sample}_R2_001_trimmed.fastq.gz"
    shell:
        """
        fastp -i DATA/FASTQ/{wildcards.sample}_R2_001.fastq.gz -o DATA/TRIMMED/{wildcards.sample}_R2_001_trimmed.fastq.gz -Q -A -G --dont_eval_duplication -b 15 -l 15
        """

rule lengthTrimBarcodesR1:
    """
