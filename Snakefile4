rule selectEmptyDroplets:
    """
    Select 100000 random empty droplets for tag counting. These will be used to get a sense of the ambient background in the cell suspension.
    """
    input:
        expand("{path004}/barcodes_copy.tsv", path004=CHROM_004UM_PATH),
        expand("{path04}/barcodes_copy.tsv", path04=CHROM_04UM_PATH),
        expand("{path4}/barcodes_copy.tsv", path4=CHROM_4UM_PATH),
        expand("{path8}/barcodes_copy.tsv", path8=CHROM_8UM_PATH),
        expand("{path004}/barcodes_copy.tsv", path004=CHROM_004UM_RAW_PATH),
        expand("{path04}/barcodes_copy.tsv", path04=CHROM_04UM_RAW_PATH),
        expand("{path4}/barcodes_copy.tsv", path4=CHROM_4UM_RAW_PATH),
        expand("{path8}/barcodes_copy.tsv", path8=CHROM_8UM_RAW_PATH)
        
    output:
        expand("{path004}/emptyDropletBarcodes_100K.tsv", path004=CHROM_004UM_RAW_PATH),
        expand("{path04}/emptyDropletBarcodes_100K.tsv", path04=CHROM_04UM_RAW_PATH),
        expand("{path4}/emptyDropletBarcodes_100K.tsv", path4=CHROM_4UM_RAW_PATH),
        expand("{path8}/emptyDropletBarcodes_100K.tsv", path8=CHROM_8UM_RAW_PATH)
    run:
        import pandas as pd
        import random
        
        # Read in the cell barcodes (non-empty droplets)
        cells004 = pd.read_csv(input[0], header=None, dtype=str, names=['barcode'])
        cells04 = pd.read_csv(input[1], header=None, dtype=str, names=['barcode'])
        cells4 = pd.read_csv(input[2], header=None, dtype=str, names=['barcode'])
        cells8 = pd.read_csv(input[3], header=None, dtype=str, names=['barcode'])
        
        # Read in the empty droplet barcodes
        empty004 = pd.read_csv(input[4], header=None, dtype=str, names=['barcode'])
        empty04 = pd.read_csv(input[5], header=None, dtype=str, names=['barcode'])
        empty4 = pd.read_csv(input[6], header=None, dtype=str, names=['barcode'])
        empty8 = pd.read_csv(input[7], header=None, dtype=str, names=['barcode'])
        
        # Select 200000 random strings
        random004 = empty004.sample(n=200000)
        random04 = empty04.sample(n=200000)
        random4 = empty4.sample(n=200000)
        random8 = empty8.sample(n=200000)
        
        # Make sure the random barcodes don't have any real cell barcodes in them. Select the first 100K.
        filter004 = random004['barcode'].isin(cells004['barcode'])
        selectRandom004 = random004[~filter004]
        selectRandom004 = selectRandom004[0:100000]
 
        filter04 = random04['barcode'].isin(cells04['barcode'])
        selectRandom04 = random04[~filter04]
        selectRandom04 = selectRandom04[0:100000]

        filter4 = random04['barcode'].isin(cells4['barcode'])
        selectRandom4 = random4[~filter4]
        selectRandom4 = selectRandom4[0:100000]
        
        filter8 = random8['barcode'].isin(cells8['barcode'])
        selectRandom8 = random8[~filter8]
        selectRandom8 = selectRandom8[0:100000]
        
        # Write the empty droplet barcodes to new CSV files
        selectRandom004.to_csv(output[0], index=False, header=False)
        selectRandom04.to_csv(output[1], index=False, header=False)
        selectRandom4.to_csv(output[2], index=False, header=False)
        selectRandom8.to_csv(output[3], index=False, header=False)
    
rule translateBarcodes:
    """
    Each barcode bead has two sets of barcode sequences: one set for the mRNA capture oligos, one for the feature capture oligos. These sets are different, so there needs to be a mapping from one to the other.
    """
    input:
        expand("{path004}/barcodes_copy.tsv", path004=CHROM_004UM_PATH),
        expand("{path04}/barcodes_copy.tsv", path04=CHROM_04UM_PATH),
        expand("{path4}/barcodes_copy.tsv", path4=CHROM_4UM_PATH),
        expand("{path8}/barcodes_copy.tsv", path8=CHROM_8UM_PATH)
    output:
        expand("{path004}/rnaToHtoTranslated.csv", path004=CHROM_004UM_PATH),
        expand("{path04}/rnaToHtoTranslated.csv", path04=CHROM_04UM_PATH),
        expand("{path4}/rnaToHtoTranslated.csv", path4=CHROM_4UM_PATH),
        expand("{path8}/rnaToHtoTranslated.csv", path8=CHROM_8UM_PATH)
    run:
        import pandas as pd
        for i,j in zip(input, output):
            translator = pd.read_csv(TRANSLATOR_PATH, header=None, dtype=str, sep="\t")
            barcodes = pd.read_csv(i, header=None, dtype=str)
            barcodes = barcodes.map(lambda x: x[:-2]) # Remove the trailing "-1" from the barcodes
            rna_to_hto_translated = translator[translator[0].isin(barcodes[0])][1] # Keeping the original order is not important here
            rna_to_hto_translated.to_csv(j, index=False, header=False)
           
